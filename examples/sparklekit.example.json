{
  "$schema": "https://leontofficial.github.io/SparkleReleaseKit/schema/sparklekit.schema.json",
  "app": {
    "bundleIdentifier": "com.example.MyApp",
    "minimumMacOS": "13.0",
    "name": "My App",
    "style": "swiftUI"
  },
  "distribution": {
    "allowAdHocSigning": true,
    "expectedArchitectures": [
      "arm64",
      "x86_64"
    ],
    "installer": "dmg",
    "releaseMode": "free",
    "requireDeveloperID": false,
    "requireNotarization": false,
    "requireSparkleSignature": true,
    "updateArchive": "zip"
  },
  "github": {
    "owner": "ExampleDeveloper",
    "pagesBranch": "gh-pages",
    "repository": "MyApp"
  },
  "project": {
    "configuration": "Release",
    "container": "My App.xcodeproj",
    "infoPlist": "My App/Info.plist",
    "scheme": "My App"
  },
  "schemaVersion": 2,
  "updates": {
    "automaticChecks": true,
    "automaticDownloads": false,
    "channel": null,
    "feedURL": "https://exampledeveloper.github.io/MyApp/appcast.xml",
    "publicEDKey": "",
    "sparkleVersion": "2.9.4"
  }
}
